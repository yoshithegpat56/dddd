-- Safely require modules
local function safeRequire(path)
    local success, module = pcall(function()
        return require(path)
    end)
    if success then
        debugLog("Successfully loaded:", tostring(path))
        return module
    else
        debugLog("Failed to load:", tostring(path), "-", tostring(module))
        return nil
    end
end

