-- Safe debug logging function
local function debugLog(...)
    if _G.debugMode then
        local args = {...}
        local message = "[DEBUG " .. os.date("%H:%M:%S") .. "] "
        for i, v in ipairs(args) do
            message = message .. tostring(v) .. " "
        end
        print(message)
    end
end

